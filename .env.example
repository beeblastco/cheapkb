# Embedding provider configuration
# Point to your embedding API endpoint (OpenAI-compatible /v1/embeddings)
EMBEDDING_PROVIDER_URL=https://your-embedding-endpoint.example.com
EMBEDDING_API_KEY=your-embedding-api-key
EMBEDDING_MODEL=text-embedding-3-small

# Chunking configuration
# Maximum number of tokens per chunk (default: 700)
CHUNK_MAX_TOKENS=700
CHUNK_OVERLAP_TOKENS=100
MAX_UPLOAD_BYTES=10485760
MAX_CHUNKS_PER_DOCUMENT=200

# Optional: Batch sizes for vectorization and embedding
# VECTOR_BATCH: Number of vectors to process in a single batch (default: 500)
VECTOR_BATCH=500
# EMBED_BATCH: Number of embeddings to process in a single batch (default: 25)
EMBED_BATCH=25

# App origin for shoo.dev JWT audience verification
APP_ORIGIN=http://localhost:5173
